# Docker Development Environment Configuration
# This file is automatically copied to .env.docker when running docker-dev
#
# All variables have sensible defaults. Only uncomment and modify
# values if you need to customize the development environment.

# Database credentials (defaults work out of the box)
# SPAIRE_POSTGRES_USER=spaire
# SPAIRE_POSTGRES_PWD=spaire
# SPAIRE_POSTGRES_DATABASE=spaire
# SPAIRE_POSTGRES_READ_USER=spaire_read
# SPAIRE_POSTGRES_READ_PWD=spaire

# MinIO credentials (defaults work out of the box)
# SPAIRE_MINIO_USER=spaire
# SPAIRE_MINIO_PWD=spairespaire
# SPAIRE_AWS_ACCESS_KEY_ID=spaire-development
# SPAIRE_AWS_SECRET_ACCESS_KEY=spaire123456789
# SPAIRE_S3_FILES_BUCKET_NAME=spaire-s3
# SPAIRE_S3_FILES_PUBLIC_BUCKET_NAME=spaire-s3-public

# Optional: GitHub integration (for full OAuth features)
# SPAIRE_GITHUB_CLIENT_ID=
# SPAIRE_GITHUB_CLIENT_SECRET=
# SPAIRE_GITHUB_APP_NAMESPACE=

# Optional: Stripe integration (for payment features)
# SPAIRE_STRIPE_SECRET_KEY=
# SPAIRE_STRIPE_PUBLISHABLE_KEY=
# SPAIRE_STRIPE_WEBHOOK_SECRET=
# SPAIRE_STRIPE_CONNECT_WEBHOOK_SECRET=

# Optional: Prometheus remote write URL
# SPAIRE_PROMETHEUS_REMOTE_WRITE_URL=
