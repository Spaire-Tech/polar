# Spaire Development Secrets
# Copy to ~/.config/spaire/secrets.env and fill in values
#
# This file is used to share secrets across multiple Git worktrees.
# Run ./dev/setup-environment to automatically merge these into server/.env

# GitHub OAuth - create app at https://github.com/settings/apps
# Or run: ./dev/setup-environment --setup-github-app
SPAIRE_GITHUB_CLIENT_ID=
SPAIRE_GITHUB_CLIENT_SECRET=
SPAIRE_GITHUB_APP_WEBHOOK_SECRET=
SPAIRE_GITHUB_APP_IDENTIFIER=
SPAIRE_GITHUB_APP_PRIVATE_KEY=
SPAIRE_GITHUB_APP_NAMESPACE=

# GitHub Repository Benefits App (usually same as above)
SPAIRE_GITHUB_REPOSITORY_BENEFITS_APP_NAMESPACE=
SPAIRE_GITHUB_REPOSITORY_BENEFITS_APP_IDENTIFIER=
SPAIRE_GITHUB_REPOSITORY_BENEFITS_APP_PRIVATE_KEY=
SPAIRE_GITHUB_REPOSITORY_BENEFITS_CLIENT_ID=
SPAIRE_GITHUB_REPOSITORY_BENEFITS_CLIENT_SECRET=

# Stripe - from https://dashboard.stripe.com/test/apikeys
SPAIRE_STRIPE_SECRET_KEY=
SPAIRE_STRIPE_PUBLISHABLE_KEY=
SPAIRE_STRIPE_WEBHOOK_SECRET=
SPAIRE_STRIPE_CONNECT_WEBHOOK_SECRET=
